[Unit]
Description=NetConfigHub - Network Configuration Backup Platform
After=network.target

[Service]
Type=simple
User=nch
Group=nch
WorkingDirectory=/opt/netconfighub
Environment=NCH_CONFIG_PATH=/etc/netconfighub/config.yaml
ExecStart=/opt/netconfighub/netconfighub
Restart=on-failure
RestartSec=5
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
